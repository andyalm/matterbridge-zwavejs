{
  "name": "matterbridge-zwavejs",
  "version": "0.1.0",
  "description": "Matterbridge plugin to expose Z-Wave JS devices as Matter devices",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "watch": "tsc --watch",
    "lint": "eslint src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:link": "npm link matterbridge"
  },
  "keywords": [
    "matterbridge",
    "matter",
    "zwave",
    "zwave-js",
    "smart-home",
    "iot"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andyalm/matterbridge-zwavejs"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "jiti": "^2.4.0",
    "prettier": "^3.4.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.0.0"
  }
}
